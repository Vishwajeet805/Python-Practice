   "source": [
    "# Filter negative and zero\n",
    "numbers = [-4, -3, -2, -1, 0, 2, 4, 6]\n",
    "\n",
    "filtered = [n for n in numbers if n <= 0]\n",
    "print(filtered)\n",
    "\n",
    "\n",
    "# Flatten list of lists\n",
    "list_of_lists = [[1,2,3],[4,5,6],[7,8,9]]\n",
    "\n",
    "flat = [num for sublist in list_of_lists for num in sublist]\n",
    "print(flat)"
   ]
  }
